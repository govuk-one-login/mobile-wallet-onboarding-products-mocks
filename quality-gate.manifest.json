{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.1.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "status-list-mock",
      "quality-gates": [
        {
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": ".github/workflows/status-list-mock-pull-request-checks.yml",
            "path": "jobs.check-sam-template-formatting"
          },
          "check-types": [
            "code style and linting"
          ]
        },
        {
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": ".github/workflows/status-list-mock-pull-request-checks.yml",
            "path": "jobs.validate-and-build-sam-template"
          },
          "check-types": [
            "code style and linting",
            "unit",
            "unit test coverage",
            "code quality",
            "vulnerability detection",
            "secret scanning"
          ]
        },
        {
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": ".github/workflows/status-list-mock-pull-request-checks.yml",
            "path": "jobs.run-checkov"
          },
          "check-types": [
            "code quality",
            "vulnerability detection"
          ]
        },
        {
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": ".github/workflows/status-list-mock-pull-request-checks.yml",
            "path": "jobs.check-oas-for-drift"
          },
          "check-types": [
            "code quality"
          ]
        },
        {
          "phase": "pre-upload",
          "provider": "GitHub",
          "config": {
            "file": ".github/workflows/status-list-mock-push-to-main.yml",
            "path": "jobs.check-sam-template-formatting"
          },
          "check-types": [
            "code style and linting"
          ]
        },
        {
          "phase": "pre-upload",
          "provider": "GitHub",
          "config": {
            "file": ".github/workflows/status-list-mock-push-to-main.yml",
            "path": "jobs.run-checkov"
          },
          "check-types": [
            "code quality",
            "vulnerability detection"
          ]
        },
        {
          "phase": "pre-upload",
          "provider": "GitHub",
          "config": {
            "file": ".github/workflows/status-list-mock-push-to-main.yml",
            "path": "jobs.deploy"
          },
          "check-types": [
            "code style and linting",
            "unit",
            "unit test coverage",
            "code quality",
            "vulnerability detection",
            "secret scanning"
          ]
        }
      ]
    }
  ]
}
