{
  "name": "status-list-mock",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "sam build --template template.yaml",
    "dev": "npm run localAws:up && npm run invoke:JwksFunction && npm run start:api",
    "checkov": "checkov --file ./template.yaml",
    "format": "./node_modules/.bin/prettier --write '**/*.ts' 'openApiSpec/mock/api-spec.yaml'",
    "lint": "./node_modules/.bin/eslint ./src/functions",
    "lint:fix": "eslint . --fix",
    "format:check": "./node_modules/.bin/prettier --check '**/*.ts'",
    "infra:format": "rain fmt --write template.yaml",
    "infra:format:check": "rain fmt --verify template.yaml",
    "invoke:JwksFunction": "sam local invoke JwksFunction --template .aws-sam/build/template.yaml --env-vars .env.json",
    "localAws:down": "docker compose -f localAws/docker-compose.yml down",
    "localAws:up": "docker compose -f localAws/docker-compose.yml up --build -d --wait",
    "start:api": "sam local start-api --template .aws-sam/build/template.yaml --warm-containers EAGER --env-vars .env.json --port 3000",
    "test": "./node_modules/.bin/jest --silent",
    "test:conformance:local": "./node_modules/.bin/jest --config jest.conformance.config.ts --testPathPatterns='runners/local'",
    "test:conformance:ci": "./node_modules/.bin/jest --config jest.conformance.config.ts --testPathPatterns='runners/ci'"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stoplight/prism-cli": "^5.15.11",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.1",
    "@aws-sdk/client-kms": "^3.1073.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "ecdsa-sig-formatter": "^1.0.11",
    "esbuild": "^0.28.1",
    "tsc": "^2.0.4"
  },
  "overrides": {
    "lodash": "4.18.0",
    "uuid": "14.0.0",
    "@tootallnate/once": "3.0.1"
  }
}
